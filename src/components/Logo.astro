---
/**
 * Logo.astro
 * Reusable wedding logo component
 */

export interface LogoProps {
  leftText?: string;
  rightText?: string;
  imageSrc?: string;
  imageAlt?: string;
  imageWidth?: number;
  className?: string;
}

// Default props
const {
  leftText = 'E',
  rightText = 'L',
  imageSrc = '/img/ring.png',
  imageAlt = 'Wedding Ring Logo',
  imageWidth = 48,
  className = '',
} = Astro.props;
---

<div class={`font-serif text-4xl font-bold text-botanical tracking-wide flex items-center gap-2 ${className}`}>
  <span>{leftText}</span>
  <img
    src={imageSrc}
    alt={imageAlt}
    width={imageWidth}
    height={imageWidth}
    loading="lazy"
  />
  <span>{rightText}</span>
</div>
