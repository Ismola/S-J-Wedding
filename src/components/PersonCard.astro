---
export interface PersonCardProps {
  image: string;
  imageAlt?: string;
  name: string;
  description: string;
}

const {
  image,
  imageAlt = '',
  name,
  description,
} = Astro.props;
---

<div class="relative">
  <div class="text-center p-6 border border-taupe bg-ivory hover:shadow-lg transition-all duration-300 hover:-translate-y-1">
    <div class="size-24 rounded-full overflow-hidden mx-auto mb-6">
      <img
        src={image}
        alt={imageAlt || name}
        loading="lazy"
        class="w-full h-full object-cover"
      />
    </div>

    <h3 class="font-serif text-xl font-semibold text-botanical mb-1">
      {name}
    </h3>
    <p class="text-gray-600 text-sm leading-relaxed">
      {description}
    </p>
  </div>
</div>
