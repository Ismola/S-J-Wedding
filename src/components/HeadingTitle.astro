---
export interface HeadingTitleProps {
  title?: string;
  description?: string;
  align?: 'center' | 'left';
  dividerColor?: string;
  className?: string;
}

// Default props
const {
  title = 'Section Title',
  description = '',
  align = 'center',
  dividerColor = 'via-sage',
  className = '',
} = Astro.props;

// Alignment classes
const alignClass =
  align === 'left'
    ? 'text-left'
    : 'text-center';
---

<div class={`mb-16 ${alignClass} ${className}`}>
  <h2 class="font-serif text-4xl md:text-5xl font-light text-botanical mb-6">
    {title}
  </h2>

  <div
    class={`w-40 h-0.5 bg-linear-to-r from-transparent ${dividerColor} to-transparent mx-auto mt-8`}
  ></div>

  {description && (
    <p class="text-gray-600 mt-6 max-w-2xl mx-auto">
      {description}
    </p>
  )}
</div>