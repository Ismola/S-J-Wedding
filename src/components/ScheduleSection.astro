---
import HeadingTitle from "./HeadingTitle.astro";

/* =========================
   SECTION CONFIG
========================= */
const section = {
  id: "schedule",
  title: "Itinerario",
};

/* =========================
   SCHEDULE DATA
========================= */
type ScheduleItem = {
  title: string;
  description: string;
  time: string;
};

type ScheduleDay = {
  dayTitle: string;
  items: ScheduleItem[];
};

const schedules: ScheduleDay[] = [
  {
    dayTitle: "Boda",
    items: [
      {
        title: "Ceremonia",
        description: "Por favor, llegad entre 15 y 30 minutos antes.",
        time: "18:00",
      },
      {
        title: "Cóctel",
        description: "A continuación de la ceremonia.",
        time: "20:15",
      },
      {
        title: "Cena",
        description:
          "Tataki de salmón al soplete · Sorbete de limón · Solomillo de vaca braseado con patatas al horno · Cheese cake con confitura de arándanos · Opción de menús vegetarianos.",
        time: "21:30",
      },
      {
        title: "Baile",
        description: "Después de la cena.",
        time: "Después de la cena",
      },
    ],
  },
];
---

<!-- Cambiar itinerario -->
<section id={section.id} class="py-20 md:py-24 bg-ivory">
  <div class="max-w-7xl mx-auto px-4">
    <!-- Heading -->
    <HeadingTitle title={section.title} />

    <!-- Schedule List -->
    <div class=" mx-auto space-y-6 ">
      {
        schedules.map((day: ScheduleDay) => (
          <div class="bg-linear-to-br from-mist to-white border-l-4 border-botanical p-8 shadow-sm rounded-r-2xl">
            <h3 class="font-serif text-3xl font-semibold text-botanical mb-6">
              {day.dayTitle}
            </h3>

            <div class={day.items.length > 1 ? "space-y-6" : ""}>
              {day.items.map((item: ScheduleItem) => (
                <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
                  <div>
                    <p class="font-semibold text-lg text-botanical">
                      {item.title}
                    </p>
                    <p
                      class="schedule-description text-stone-600 mt-2 text-sm md:text-base leading-relaxed"
                      set:html={item.description}
                    />
                  </div>

                  <span class="font-serif text-2xl text-sage whitespace-nowrap">
                    {item.time}
                  </span>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .schedule-description :global(strong) {
    color: var(--color-botanical);
    font-weight: 700;
  }

  .schedule-description :global(em) {
    color: var(--color-sage);
    font-style: italic;
  }

  .schedule-description :global(ul),
  .schedule-description :global(ol) {
    margin-top: 0.5rem;
    padding-left: 1.25rem;
  }

  .schedule-description :global(li + li) {
    margin-top: 0.2rem;
  }

  .schedule-description :global(br) {
    line-height: 1.8;
  }
</style>
