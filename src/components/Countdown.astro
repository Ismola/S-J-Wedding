---
interface NotificationItem {
  id: string;
  message: string;
}

export interface CountdownProps {
  targetDate?: string; // ISO string
  labels?: {
    days: string;
    hours: string;
    minutes: string;
    seconds: string;
  };
  completedMessage?: string;
  notifications?: NotificationItem[];
}

// Default props
const {
  targetDate = "2026-06-15T15:00:00",
  labels = {
    days: "Días",
    hours: "Horas",
    minutes: "Minutos",
    seconds: "Segundos",
  },
  completedMessage = "",
  notifications = [
    {
      id: "pre-wedding-photo",
      message:
        "Nos gustaría tener alguna foto tuya antes de la boda. Si quieres compartirla, por favor envíala a través de WhatsApp. \n¡Muchas gracias! ❤️",
    },
  ] as NotificationItem[],
} = Astro.props;

const countdownId = `countdown-${Math.random().toString(36).slice(2)}`;
---

<div>
  {
    notifications.length > 0 && (
      <div
        data-notifications
        class="fixed top-22 left-3 md:left-6 z-9999 space-y-3 pointer-events-none"
      >
        {notifications.map((notification: NotificationItem) => (
          <div
            data-notification={notification.id}
            class="hidden relative w-[calc(100vw-1.5rem)] md:w-full max-w-md rounded-2xl border border-white/40 bg-botanical/85 backdrop-blur-lg p-4 md:p-5 text-left text-white shadow-2xl pointer-events-auto"
          >
            <button
              type="button"
              data-notification-close={notification.id}
              class="absolute top-3 right-3 flex h-8 w-8 items-center justify-center rounded-full bg-white/15 text-xl leading-none transition hover:bg-white/25"
              aria-label="Cerrar notificación"
            >
              ×
            </button>
            <p class="pr-10 text-sm md:text-base leading-relaxed whitespace-pre-line">
              {notification.message}
            </p>
          </div>
        ))}
      </div>
    )
  }

  <!-- Countdown -->
  <div id={countdownId} class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
    {
      (
        [
          { key: "days", label: labels.days },
          { key: "hours", label: labels.hours },
          { key: "minutes", label: labels.minutes },
          { key: "seconds", label: labels.seconds },
        ] as const
      ).map(
        (item: {
          key: "days" | "hours" | "minutes" | "seconds";
          label: string;
        }) => (
          <div class="bg-white/10 backdrop-blur-lg rounded-2xl p-6 shadow-2xl border border-white/20">
            <div class="text-center">
              <div
                data-unit={item.key}
                class="text-5xl md:text-6xl font-bold text-white mb-2"
              >
                00
              </div>
              <div class="text-sm md:text-base text-gray-300 uppercase tracking-wider">
                {item.label}
              </div>
            </div>
          </div>
        ),
      )
    }
  </div>

  <!-- Completed Message -->
  <div data-message class="hidden mt-8 text-center">
    <p class="text-2xl md:text-3xl font-bold text-white">
      {completedMessage}
    </p>
  </div>
</div>

<script define:vars={{ targetDate, countdownId }}>
  const targetTime = new Date(targetDate).getTime();

  const container = document.getElementById(countdownId);

  if (container) {
    const message = container.parentElement?.querySelector("[data-message]");
    const notificationsWrapper = container.parentElement?.querySelector(
      "[data-notifications]",
    );
    const notificationItems = Array.from(
      container.parentElement?.querySelectorAll("[data-notification]") ?? [],
    );
    const closeButtons = Array.from(
      container.parentElement?.querySelectorAll("[data-notification-close]") ??
        [],
    );

    const elements = {
      days: container.querySelector('[data-unit="days"]'),
      hours: container.querySelector('[data-unit="hours"]'),
      minutes: container.querySelector('[data-unit="minutes"]'),
      seconds: container.querySelector('[data-unit="seconds"]'),
    };

    const pad = (n) => (n < 10 ? "0" + n : n);
    const storagePrefix = "wedding-notification-dismissed:";

    const updateNotifications = (isActive) => {
      let visibleCount = 0;

      notificationItems.forEach((item) => {
        const id = item.getAttribute("data-notification");
        if (!id) return;

        const isDismissed =
          localStorage.getItem(`${storagePrefix}${id}`) === "true";
        const shouldShow = isActive && !isDismissed;

        item.classList.toggle("hidden", !shouldShow);
        if (shouldShow) visibleCount += 1;
      });

      notificationsWrapper?.classList.toggle("hidden", visibleCount === 0);
    };

    closeButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const id = button.getAttribute("data-notification-close");
        if (!id) return;

        localStorage.setItem(`${storagePrefix}${id}`, "true");
        updateNotifications(targetTime - Date.now() > 0);
      });
    });

    const updateCountdown = () => {
      const now = Date.now();
      const distance = targetTime - now;

      if (distance <= 0) {
        container.classList.add("hidden");
        message?.classList.remove("hidden");
        updateNotifications(false);
        return false;
      }

      const days = Math.floor(distance / (1000 * 60 * 60 * 24));
      const hours = Math.floor((distance / (1000 * 60 * 60)) % 24);
      const minutes = Math.floor((distance / (1000 * 60)) % 60);
      const seconds = Math.floor((distance / 1000) % 60);

      elements.days.textContent = pad(days);
      elements.hours.textContent = pad(hours);
      elements.minutes.textContent = pad(minutes);
      elements.seconds.textContent = pad(seconds);
      updateNotifications(true);

      return true;
    };

    const isActive = updateCountdown();

    if (isActive) {
      const timer = setInterval(() => {
        const stillActive = updateCountdown();
        if (!stillActive) clearInterval(timer);
      }, 1000);
    }
  }
</script>
