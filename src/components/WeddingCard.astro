---
/**
 * WeddingCard.astro
 */

import { Icon } from 'astro-icon/components';

export interface CardItem {
  icon: string; // contoh: "bi:calendar-event"
  label: string;
  title: string;
  subtitle?: string;
  description?: string;
}

export interface WeddingCardProps {
  image: string;
  imageAlt?: string;
  title: string;
  tagline?: string;
  headerIcon?: string; // astro-icon name
  items: CardItem[];
  mapUrl?: string;
  showAllergyButton?: boolean;
  allergyApiPath?: string;
  allergyListPath?: string;
  allergyStorageKey?: string;
}

const {
  image,
  imageAlt = '',
  title,
  tagline,
  headerIcon = 'bi:heart-fill',
  items,
  mapUrl = 'https://maps.google.com',
  showAllergyButton = false,
  allergyApiPath = '/api/allergies',
  allergyListPath = '/alergias',
  allergyStorageKey = 'sj-wedding-allergies',
} = Astro.props;

function getOneHourBefore(timeStr: string): string | null {
  const match = timeStr.match(/^(\d{1,2}):(\d{2})$/);
  if (!match) return null;
  const hours = (parseInt(match[1], 10) - 1 + 24) % 24;
  return `${hours.toString().padStart(2, '0')}:${match[2]}`;
}

const alpineState = showAllergyButton
  ? `{
      showAllergyModal: false,
      guestName: '',
      guestAllergy: '',
      allergies: [],
      saving: false,
      error: '',
      success: '',
      init() {
        try {
          const saved = localStorage.getItem('${allergyStorageKey}');
          this.allergies = saved ? JSON.parse(saved) : [];
        } catch (error) {
          console.error('No se pudieron cargar las alergias guardadas.', error);
        }
      },
      async saveAllergy() {
        this.error = '';
        this.success = '';

        const name = this.guestName.trim();
        const allergy = this.guestAllergy.trim();

        if (!name || !allergy) {
          this.error = 'Completa el nombre y la alergia o intolerancia.';
          return;
        }

        const entry = {
          id: Date.now(),
          name,
          allergy,
          createdAt: new Date().toISOString(),
        };

        this.allergies = [entry, ...this.allergies];
        localStorage.setItem('${allergyStorageKey}', JSON.stringify(this.allergies));
        this.saving = true;

        try {
          const response = await fetch('${allergyApiPath}', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify(entry),
          });

          if (!response.ok) {
            throw new Error('Error al guardar en MongoDB');
          }

          this.success = 'Alergia guardada correctamente.';
          this.guestName = '';
          this.guestAllergy = '';
          this.showAllergyModal = false;
        } catch (error) {
          console.error(error);
          this.error = 'Se ha guardado en este dispositivo, pero no se pudo sincronizar con la base de datos.';
        } finally {
          this.saving = false;
        }
      }
    }`
  : '{}';
---

<div x-data={alpineState} class="bg-white rounded-xl shadow-sm border border-mist overflow-hidden hover:shadow-2xl transition-all duration-300">
  <!-- Image -->
  <div class="relative overflow-hidden group">
    <img
      src={image}
      alt={imageAlt}
      loading="lazy"
      class="w-full h-64 object-cover transition-transform duration-500 group-hover:scale-110"
    />
    <div class="absolute inset-0 bg-linear-to-t from-dark/80 via-botanical/50 to-transparent"></div>

    <div class="absolute bottom-0 left-0 right-0 p-6 text-white">
      <div class="flex items-center gap-3 mb-2">
        <Icon name={headerIcon} class="w-6 h-6" />
        <h3 class="font-serif text-4xl font-semibold">{title}</h3>
      </div>
      {tagline && <p class="text-white/90 text-sm">{tagline}</p>}
    </div>
  </div>

  <!-- Content -->
  <div class="p-8 space-y-5">
    {items.map((item: CardItem) => (
      <div class="flex items-start gap-4 pb-5 border-b last:border-0 border-mist">
        <div class="bg-sage/10 p-3 rounded-lg shrink-0">
          <Icon name={item.icon} class="w-6 h-6 text-sage" />
        </div>

        <div class="w-full">
          <div class="flex flex-row justify-between w-full ">

          <p class="text-xs uppercase tracking-wider text-sage font-semibold mb-1">
            {item.label}
          </p>
             {getOneHourBefore(item.title) && (
            <p class="text-xs uppercase tracking-wider text-sage font-semibold mb-1">Canarias</p>
          )}
          </div>
          <div class="flex flex-row justify-between w-full ">

          <p class="text-lg font-semibold text-botanical">{item.title}</p>
          {getOneHourBefore(item.title) && (
            <p class="text-lg font-semibold text-botanical">{getOneHourBefore(item.title)}</p>
          )}
          </div>
          {item.subtitle && (
            <p class="text-sm text-gray-500 mt-1">{item.subtitle}</p>
          )}
          {item.description && (
            <p class="text-gray-600 mt-2">{item.description}</p>
          )}
        </div>
      </div>
    ))}

    <div class="mt-8 space-y-4">
      <div class="flex flex-col  gap-3">
        <a
          href={mapUrl}
          target="_blank"
          class="flex items-center justify-center py-3 px-6 bg-botanical text-white gap-2 rounded-lg hover:bg-botanical/90"
        >
          <Icon name="bi:map" class="w-5 h-5" />
          Obtener dirección
        </a>

        {showAllergyButton && (
          <button
            type="button"
            @click="showAllergyModal = true"
            class="flex items-center justify-center gap-2 border-2 border-botanical text-botanical px-6 py-3 rounded-lg hover:bg-botanical hover:text-white transition-all"
          >
            <Icon name="bi:heart-pulse-fill" class="w-5 h-5" />
            Añadir alergia o intolerancia
          </button>
        )}

        <!-- <button
          @click="$dispatch('open-rundown')"
          class="flex items-center gap-2 border-2 border-botanical text-botanical px-6 py-3 rounded-lg hover:bg-botanical hover:text-white transition-all"
        >
          <Icon name="bi:send" class="w-5 h-5" />
          Rundown
        </button> -->
      </div>

      {showAllergyButton && (
        <>
          <p x-show="success" x-text="success" class="text-sm text-green-700 font-medium"></p>
          <p x-show="error" x-text="error" class="text-sm text-rose-700 font-medium"></p>

          <div class="rounded-xl border border-mist bg-mist/30 p-4" x-show="allergies.length > 0">
            <div class="flex items-center justify-between gap-2 mb-3">
              <p class="text-sm font-semibold text-botanical">Alergias guardadas</p>
              {/* <a href={allergyListPath} class="text-sm text-sage hover:underline">Ver listado</a> */}
            </div>

            <div class="space-y-2">
              <template x-for="entry in allergies" :key="entry.id">
                <div class="flex items-start gap-2 text-sm text-gray-700">
                  <Icon name="bi:check-circle-fill" class="w-4 h-4 text-sage mt-0.5 shrink-0" />
                  <p>
                    <span class="font-semibold" x-text="entry.name"></span>
                    <span> — </span>
                    <span x-text="entry.allergy"></span>
                  </p>
                </div>
              </template>
            </div>
          </div>

          <div
            x-show="showAllergyModal"
            x-cloak
            style="display: none;"
            class="fixed inset-0 z-50 flex items-center justify-center bg-black/60 p-4 backdrop-blur-sm"
            @click="showAllergyModal = false"
            @keydown.escape.window="showAllergyModal = false"
          >
            <div @click.stop class="w-full max-w-lg rounded-2xl bg-white p-6 shadow-2xl">
              <div class="mb-5 flex items-start justify-between gap-4">
                <div>
                  <h4 class="font-serif text-3xl text-botanical">Alergias e intolerancias</h4>
                  <p class="mt-1 text-sm text-gray-500">Añade el nombre del invitado y su alergia para el banquete.</p>
                </div>
                <button
                  type="button"
                  @click="showAllergyModal = false"
                  class="rounded-full bg-sage/10 p-2 text-botanical hover:bg-sage/20"
                >
                  <Icon name="bi:x-lg" class="w-4 h-4" />
                </button>
              </div>

              <form class="space-y-4" @submit.prevent="saveAllergy()">
                <div>
                  <label class="mb-2 block text-sm font-medium text-botanical">Nombre</label>
                  <input
                    type="text"
                    x-model="guestName"
                    placeholder="Nombre del invitado"
                    class="w-full rounded-lg border border-mist px-4 py-3 focus:outline-none focus:ring-2 focus:ring-sage/30"
                  />
                </div>

                <div>
                  <label class="mb-2 block text-sm font-medium text-botanical">Alergia o intolerancia</label>
                  <textarea
                    rows="3"
                    x-model="guestAllergy"
                    placeholder="Ej. frutos secos, lactosa, gluten..."
                    class="w-full rounded-lg border border-mist px-4 py-3 focus:outline-none focus:ring-2 focus:ring-sage/30"
                  ></textarea>
                </div>

                <p x-show="error" x-text="error" class="text-sm text-rose-700"></p>

                <div class="flex justify-end gap-3 pt-2">
                  <button
                    type="button"
                    @click="showAllergyModal = false"
                    class="rounded-lg border border-mist px-4 py-2 text-gray-600 hover:bg-mist/40"
                  >
                    Cancelar
                  </button>
                  <button
                    type="submit"
                    :disabled="saving"
                    class="rounded-lg bg-botanical px-5 py-2 text-white hover:bg-botanical/90 disabled:opacity-70"
                  >
                    <span x-show="!saving">Guardar</span>
                    <span x-show="saving">Guardando...</span>
                  </button>
                </div>
              </form>
            </div>
          </div>
        </>
      )}
    </div>
  </div>
</div>