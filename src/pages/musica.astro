---
import HeadingTitle from "@src/components/HeadingTitle.astro";
import MainLayout from "@src/layouts/MainLayout.astro";
import { getMusicCollection } from "@src/lib/mongodb";

let songs: Array<{
    id?: number;
    guestName: string;
    songTitle: string;
    artist?: string;
    createdAt: string;
}> = [];
let errorMessage = "";

try {
    const collection = await getMusicCollection();
    songs = await collection
        .find({}, { projection: { _id: 0 } })
        .sort({ createdAt: -1 })
        .toArray();
} catch (error) {
    console.error("Error loading music list", error);
    errorMessage = "No se ha podido cargar el listado de canciones por ahora.";
}
---

<MainLayout
    title="Música propuesta | Sergio & Judit"
    description="Listado de canciones propuestas por los invitados"
>
    <section class="bg-ivory py-20 md:py-24">
        <div class="mx-auto max-w-5xl px-4">
            <HeadingTitle
                title="Música propuesta"
                description="Aquí puedes ver las canciones que ya han dejado los invitados."
                align="center"
            />

            {
                errorMessage ? (
                    <div class="rounded-xl border border-rose-200 bg-rose-50 px-5 py-4 text-rose-700">
                        {errorMessage}
                    </div>
                ) : songs.length > 0 ? (
                    <div class="overflow-hidden rounded-2xl border border-mist bg-white shadow-sm">
                        <div class="grid grid-cols-[1.2fr_1.5fr] gap-4 border-b border-mist bg-mist/40 px-5 py-4 text-sm font-semibold text-botanical">
                            <p>Invitado</p>
                            <p>Canción</p>
                            {/* <p>Artista</p> */}
                        </div>

                        <div class="divide-y divide-mist">
                            {songs.map((entry) => (
                                <div class="grid grid-cols-1 gap-2 px-5 py-4 text-sm text-gray-700 md:grid-cols-[1.2fr_1.5fr] md:gap-4">
                                    <p class="font-semibold text-botanical">
                                        {entry.guestName}
                                    </p>
                                    <p>{entry.songTitle}</p>
                                    {/* <p>{entry.artist || "—"}</p> */}
                                </div>
                            ))}
                        </div>
                    </div>
                ) : (
                    <div class="rounded-xl border border-mist bg-white px-5 py-8 text-center text-gray-600 shadow-sm">
                        Todavía no hay canciones propuestas.
                    </div>
                )
            }
        </div>
    </section>
</MainLayout>
